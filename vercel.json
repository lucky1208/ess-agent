{
  "buildCommand": null,
  "outputDirectory": "dist",
  "publicDirectory": "public",
  "cleanUrls": false,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*).pdf",
      "headers": [
        { "key": "Content-Type", "value": "application/pdf" },
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "functions": {
    "api/*.js": {
      "maxDuration": 300
    }
  }
}